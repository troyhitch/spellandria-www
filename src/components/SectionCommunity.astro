---
const channels = [
  {
    kicker: 'Official channels',
    title: 'Discord, socials & newsletter',
    description: 'Primary calls-to-action for joining the community and following active updates.',
    href: '#',
    cta: 'Join Discord',
  },
  {
    kicker: 'Player culture',
    title: 'Fan art, guilds & creators',
    description: 'A living feed for the people who make the universe feel inhabited.',
    href: '#',
    cta: 'Explore',
  },
  {
    kicker: 'Events',
    title: 'Tournaments & world beats',
    description: 'Event tiles, livestreams, premiere dates, and collectible moments.',
    href: '#',
    cta: 'See events',
  },
];
---

<section id="community" class="max-w-screen-xl mx-auto px-6 md:px-10 pt-24">
  <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-5 items-stretch">
    <!-- Key art -->
    <div
      class="overflow-hidden min-h-[420px] md:min-h-[560px]"
      style="border-radius: 28px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 24px 80px rgba(0,0,0,0.45);"
    >
      <img
        src="/assets/generated/spellandria-community-banner.png"
        alt="Spellandria community gathering"
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Copy -->
    <div
      class="p-8 md:p-10 flex flex-col justify-center"
      style="border-radius: 28px; border: 1px solid rgba(255,255,255,0.1); background: rgba(14,10,20,0.82); backdrop-filter: blur(18px); box-shadow: 0 24px 80px rgba(0,0,0,0.45);"
    >
      <p class="uppercase tracking-[0.18em] text-xs font-black mb-3" style="color: #f5ce82;">Community</p>
      <h2 class="mb-4 text-[clamp(2rem,4.5vw,3.5rem)] leading-[0.98]">Gather the realm</h2>
      <p class="mb-8">
        AAA fantasy sites treat community as a first-class pillar. This section is the front door for Discord, social channels, events, creator programs, newsletters, and eventually competitive or guild-driven activity.
      </p>

      <div class="flex flex-col gap-4">
        {channels.map(c => (
          <article
            class="p-5 rounded-[18px] flex items-start gap-4"
            style="border: 1px solid rgba(255,255,255,0.09); background: rgba(255,255,255,0.03);"
          >
            <div class="flex-1">
              <p class="uppercase tracking-[0.16em] text-[0.68rem] font-black mb-1" style="color: #f5ce82;">{c.kicker}</p>
              <h3 class="text-base mb-1.5">{c.title}</h3>
              <p class="text-sm">{c.description}</p>
            </div>
            <a
              href={c.href}
              class="shrink-0 self-center px-4 py-2 rounded-full text-xs font-black no-underline transition-all duration-150 hover:-translate-y-px"
              style="border: 1px solid rgba(245,206,130,0.3); color: #f5ce82; background: rgba(245,206,130,0.07);"
            >
              {c.cta}
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
