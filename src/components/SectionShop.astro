---
const collections = [
  {
    kicker: 'Collector\'s line',
    title: 'Arcane artifacts & editions',
    description: 'Sealed codices, embossed sigil sets, realm maps on aged vellum, and collector\'s editions for those who want to hold a piece of the world in their hands.',
  },
  {
    kicker: 'Wear your order',
    title: 'Apparel & accessories',
    description: 'Faction crests, caster guild marks, and arcane insignia worked into apparel worthy of the dueling hall.',
  },
  {
    kicker: 'The vault',
    title: 'Limited & seasonal drops',
    description: 'Rare editions tied to world events, duel seasons, and lore milestones. When they\'re gone, they\'re gone.',
  },
];
---

<section id="shop" class="max-w-screen-xl mx-auto px-6 md:px-10 pt-24 pb-24">
  <!-- Heading -->
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
    <div>
      <p class="uppercase tracking-[0.18em] text-xs font-black" style="color: #f5ce82;">The vault</p>
      <h2 class="mt-3 text-[clamp(2.1rem,5vw,4rem)] leading-[0.98]">
        Carry the world<br />with you
      </h2>
    </div>
    <a
      href="#"
      class="inline-flex items-center font-black text-sm no-underline shrink-0 mb-1 hover:opacity-80 transition-opacity"
      style="color: #f5ce82;"
    >
      Browse the vault &rarr;
    </a>
  </div>

  <!-- Key art + collections -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Shop image -->
    <div
      class="overflow-hidden min-h-[420px]"
      style="border-radius: 28px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 24px 80px rgba(0,0,0,0.45);"
    >
      <img
        src="/assets/generated/spellandria-shop-display-clean.png"
        alt="Spellandria arcane artifacts and collector's items"
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Collections copy -->
    <div class="flex flex-col gap-5">
      <!-- Opening statement -->
      <div
        class="p-7"
        style="border-radius: 28px; border: 1px solid rgba(245,206,130,0.28); background: rgba(245,206,130,0.05); backdrop-filter: blur(12px);"
      >
        <p class="uppercase tracking-[0.18em] text-xs font-black mb-2" style="color: #f5ce82;">For those who collect as well as cast</p>
        <h3 class="text-lg mb-2">The world beyond the game</h3>
        <p class="text-sm">
          The orders of Spellandria have always known that power comes in many forms. Some of it lives on the board. Some of it belongs in your hands, on your shelf, or around your neck. The shop opens soon — join the order to be first through the vault doors.
        </p>
      </div>

      <!-- Collection tiles -->
      {collections.map(c => (
        <article
          class="p-6 flex items-start justify-between gap-4"
          style="border-radius: 22px; border: 1px solid rgba(255,255,255,0.09); background: rgba(14,10,20,0.82); backdrop-filter: blur(12px);"
        >
          <div class="flex-1">
            <p class="uppercase tracking-[0.16em] text-[0.68rem] font-black mb-1.5" style="color: #f5ce82;">{c.kicker}</p>
            <h3 class="text-lg mb-1.5">{c.title}</h3>
            <p class="text-sm">{c.description}</p>
          </div>
          <span
            class="shrink-0 self-center px-3 py-1.5 rounded-full text-xs font-black"
            style="border: 1px solid rgba(255,255,255,0.1); color: rgba(244,239,232,0.5); background: rgba(255,255,255,0.03);"
          >
            Coming soon
          </span>
        </article>
      ))}
    </div>
  </div>
</section>
