---
import type { GameConfig } from '../data/games';

interface Props {
  game: GameConfig;
}

const { game } = Astro.props;
---

<section class="relative min-h-screen overflow-hidden border-b border-white/8" id="top">
  <div
    class="absolute inset-0 -z-10"
    style="background: radial-gradient(circle at 50% 28%, rgba(255,255,255,0.06), transparent 30%), linear-gradient(180deg, #100b16 0%, #07050a 100%);"
  >
    <img
      src={game.art}
      alt=""
      aria-hidden="true"
      class="w-full h-full object-contain object-center p-8 md:p-12"
      style="filter: saturate(1.02) contrast(1.01);"
    />
  </div>

  <div
    class="absolute inset-0 -z-10"
    style="background: linear-gradient(180deg, rgba(5,3,8,0.34) 0%, rgba(5,3,8,0.28) 22%, rgba(5,3,8,0.93) 100%), linear-gradient(90deg, rgba(5,3,8,0.88) 0%, rgba(5,3,8,0.4) 50%, rgba(5,3,8,0.82) 100%);"
    aria-hidden="true"
  ></div>

  <div class="max-w-screen-xl mx-auto px-6 md:px-10 flex flex-col justify-center min-h-screen pt-28 pb-20">
    <p class="uppercase tracking-[0.18em] text-xs font-black" style="color: #f5ce82;">{game.kicker}</p>

    <h1 class="mt-5 mb-5 text-[clamp(3.25rem,8vw,6.5rem)] leading-[0.92] max-w-[10ch]" style="font-family: var(--font-display); letter-spacing: 0.02em;">
      {game.fullTitle}
    </h1>

    <p class="max-w-2xl text-[1.1rem]" style="color: rgba(244,239,232,0.8);">
      {game.tagline}
    </p>

    <p class="max-w-2xl mt-5 text-[1rem]" style="color: rgba(244,239,232,0.68);">
      {game.description}
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="#overview"
        class="inline-flex items-center justify-center px-6 h-12 rounded-full font-black text-sm transition-all duration-150 hover:-translate-y-px no-underline"
        style="background: linear-gradient(135deg,#f5ce82,#fff0c8); color: #23161b; box-shadow: 0 14px 40px rgba(245,206,130,0.24);"
      >
        Enter {game.shortTitle}
      </a>
      <a
        href="https://spellrealms.com"
        class="inline-flex items-center justify-center px-6 h-12 rounded-full font-black text-sm border transition-all duration-150 hover:-translate-y-px no-underline"
        style="border-color: rgba(255,255,255,0.16); color: #f4efe8; background: rgba(255,255,255,0.05);"
      >
        Back to SpellRealms
      </a>
    </div>

    <ul class="mt-7 flex flex-wrap gap-2.5 list-none p-0 m-0">
      {[game.status, ...game.bullets].map(item => (
        <li
          class="px-4 py-2.5 rounded-full text-sm"
          style="border: 1px solid rgba(255,255,255,0.09); background: rgba(10,8,15,0.55); color: rgba(244,239,232,0.7);"
        >
          {item}
        </li>
      ))}
    </ul>
  </div>
</section>

<section id="overview" class="max-w-screen-xl mx-auto px-6 md:px-10 py-16 md:py-20">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <article class="p-8" style="border-radius: 28px; border: 1px solid rgba(255,255,255,0.1); background: rgba(14,10,20,0.82); backdrop-filter: blur(18px);">
      <p class="uppercase tracking-[0.18em] text-xs font-black mb-3" style="color: #f5ce82;">Overview</p>
      <h2 class="text-3xl mb-4">{game.overviewTitle}</h2>
      <p>{game.overviewBody}</p>
    </article>

    <article class="p-8" style="border-radius: 28px; border: 1px solid rgba(255,255,255,0.1); background: rgba(14,10,20,0.82); backdrop-filter: blur(18px); background-image: radial-gradient(circle at 80% 0%, rgba(141,114,255,0.14), transparent 28%);">
      <p class="uppercase tracking-[0.18em] text-xs font-black mb-3" style="color: #f5ce82;">Promise</p>
      <h2 class="text-3xl mb-4">{game.promiseTitle}</h2>
      <p>{game.promiseBody}</p>
    </article>
  </div>

  <div class="mt-5 p-8" style="border-radius: 28px; border: 1px solid rgba(255,255,255,0.1); background: rgba(14,10,20,0.82); backdrop-filter: blur(18px); box-shadow: 0 24px 80px rgba(0,0,0,0.35);">
    <p class="uppercase tracking-[0.18em] text-xs font-black mb-3" style="color: #f5ce82;">Franchise link</p>
    <h2 class="text-3xl mb-4">One world, multiple chapters</h2>
    <p class="max-w-3xl" style="color: rgba(244,239,232,0.72);">
      {game.fullTitle} is one part of the larger SpellRealms universe — a connected fantasy franchise built around the dangerous idea that language itself can alter reality. Each game explores that power from a different angle while sharing the same mythic world.
    </p>
    <div class="mt-7 flex flex-wrap gap-4">
      <a
        href="https://spellrealms.com"
        class="inline-flex items-center justify-center px-6 h-12 rounded-full font-black text-sm transition-all duration-150 hover:-translate-y-px no-underline"
        style="background: linear-gradient(135deg,#f5ce82,#fff0c8); color: #23161b; box-shadow: 0 14px 40px rgba(245,206,130,0.24);"
      >
        Visit the franchise portal
      </a>
      <a
        href="#top"
        class="inline-flex items-center justify-center px-6 h-12 rounded-full font-black text-sm border transition-all duration-150 hover:-translate-y-px no-underline"
        style="border-color: rgba(255,255,255,0.16); color: #f4efe8; background: rgba(255,255,255,0.05);"
      >
        Back to top
      </a>
    </div>
  </div>
</section>
