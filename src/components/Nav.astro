---
const links = [
  { href: '#world',     label: 'World' },
  { href: '#news',      label: 'News' },
  { href: '#community', label: 'Community' },
  { href: '#shop',      label: 'Shop' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-10 py-4 backdrop-blur-md border-b border-white/8" style="background: rgba(8,5,12,0.72);">
  <a href="#top" aria-label="SpellRealms home">
    <img
      src="/assets/logo/SPELLREALMS_logo-thumb.png"
      alt="SpellRealms"
      class="h-14 w-auto max-w-[260px]"
      style="filter: drop-shadow(0 6px 18px rgba(0,0,0,0.5));"
    />
  </a>

  <ul class="hidden md:flex items-center gap-7 list-none m-0 p-0">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          class="text-sm font-bold tracking-wide text-white/70 hover:text-white transition-colors duration-150 no-underline"
        >
          {link.label}
        </a>
      </li>
    ))}
    <li>
      <a
        href="#shop"
        class="px-4 py-2 rounded-full border text-sm font-bold tracking-wide transition-all duration-150 hover:-translate-y-px no-underline"
        style="border-color: rgba(245,206,130,0.35); color: #f5ce82; background: rgba(245,206,130,0.06);"
      >
        Enter the shop
      </a>
    </li>
  </ul>

  <!-- Mobile menu placeholder -->
  <button
    class="md:hidden flex flex-col gap-1.5 p-2"
    aria-label="Open menu"
    id="menu-toggle"
  >
    <span class="block w-6 h-0.5 bg-white/70"></span>
    <span class="block w-6 h-0.5 bg-white/70"></span>
    <span class="block w-6 h-0.5 bg-white/70"></span>
  </button>
</nav>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex flex-col justify-center items-center gap-8 text-2xl font-bold hidden"
  style="background: rgba(8,5,12,0.97); backdrop-filter: blur(12px);"
>
  {links.map(link => (
    <a
      href={link.href}
      class="text-white/80 hover:text-white transition-colors no-underline mobile-nav-link"
      style="font-family: var(--font-display);"
    >
      {link.label}
    </a>
  ))}
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  menu?.querySelectorAll('.mobile-nav-link').forEach(el => {
    el.addEventListener('click', () => menu.classList.add('hidden'));
  });
</script>
