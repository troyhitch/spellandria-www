---
const featured = {
  image: '/assets/identity-thumbs/realms.png',
  category: 'Announcement',
  title: 'DuelCasters of Spellandria is coming to iOS',
  excerpt: 'The first game in the Spellandria universe is in development. Face off against rival casters, trace spells across a living board of arcane gems, and discover what happens when the right word lands at exactly the right moment.',
  href: '#',
};

const articles = [
  {
    category: 'Lore',
    title: 'The Ashcroft Guild and the War of Silent Letters',
    excerpt: 'For two hundred years, the Ashcroft Guild maintained that certain letters carried too much destructive power to be spoken aloud in competition. Then came the Silence Accords — and the casters who refused to sign them.',
    href: '#',
  },
  {
    category: 'Dev journal',
    title: 'Why spelling is the perfect combat mechanic',
    excerpt: 'When we decided that words should become weapons in Spellandria, we had to ask ourselves: what makes a word powerful? Length, rarity, precision — or something else entirely?',
    href: '#',
  },
  {
    category: 'World',
    title: 'Inside the Luminant Academy: first look',
    excerpt: 'The oldest arcane institution in Spellandria accepts fewer than a dozen students each cycle. We spoke to three graduates about what it\'s like to train inside the eastern spires.',
    href: '#',
  },
];
---

<section id="news" class="max-w-screen-xl mx-auto px-6 md:px-10 pt-24">
  <!-- Heading -->
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
    <div>
      <p class="uppercase tracking-[0.18em] text-xs font-black" style="color: #f5ce82;">Dispatches from Spellandria</p>
      <h2 class="mt-3 text-[clamp(2.1rem,5vw,4rem)] leading-[0.98]">
        News, lore &<br />announcements
      </h2>
    </div>
    <a
      href="#"
      class="inline-flex items-center font-black text-sm no-underline shrink-0 mb-1"
      style="color: #f5ce82;"
    >
      All dispatches &rarr;
    </a>
  </div>

  <!-- Featured article -->
  <article
    class="overflow-hidden mb-5 grid md:grid-cols-[1.2fr_0.8fr]"
    style="border-radius: 28px; border: 1px solid rgba(255,255,255,0.1); background: rgba(14,10,20,0.82); backdrop-filter: blur(18px); box-shadow: 0 24px 80px rgba(0,0,0,0.45);"
  >
    <div class="relative min-h-[280px]">
      <img
        src={featured.image}
        alt="Realms of Spellandria — the next chapter"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(8,5,12,0.12), rgba(8,5,12,0.72));" aria-hidden="true"></div>
    </div>
    <div class="flex flex-col justify-center p-8">
      <p class="uppercase tracking-[0.18em] text-xs font-black mb-3" style="color: #f5ce82;">{featured.category}</p>
      <h3 class="text-2xl md:text-3xl mb-4">{featured.title}</h3>
      <p class="mb-6">{featured.excerpt}</p>
      <a
        href={featured.href}
        class="font-black text-sm no-underline hover:opacity-80 transition-opacity"
        style="color: #f4efe8;"
      >
        Read more &rarr;
      </a>
    </div>
  </article>

  <!-- Article grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    {articles.map(a => (
      <article
        class="p-7 flex flex-col"
        style="border-radius: 28px; border: 1px solid rgba(255,255,255,0.1); background: rgba(14,10,20,0.82); backdrop-filter: blur(18px);"
      >
        <p class="uppercase tracking-[0.18em] text-xs font-black mb-3" style="color: #f5ce82;">{a.category}</p>
        <h3 class="text-xl mb-3">{a.title}</h3>
        <p class="text-sm flex-1 mb-5">{a.excerpt}</p>
        <a
          href={a.href}
          class="font-black text-sm no-underline hover:opacity-80 transition-opacity"
          style="color: #f4efe8;"
        >
          Read more &rarr;
        </a>
      </article>
    ))}
  </div>
</section>
